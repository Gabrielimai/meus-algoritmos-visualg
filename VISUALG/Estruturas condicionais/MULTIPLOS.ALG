Algoritmo "Multiplos"


// Data atual  : 18/02/2026
Var
   numero1, numero2 : inteiro


Inicio

   escreval("Digite dois numeros inteiros: ")
   leia(numero1)
   leia(numero2)

   se (numero1 % 2 = 0) e (numero2 % 2 = 0) entao
      escreva("Sao multiplos")
   senao
      escreva("n„o s„o multiplos")
   fimse


Fimalgoritmo