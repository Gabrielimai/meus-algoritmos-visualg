Algoritmo "Estruturas Condicionais baskara"

// Data atual  : 14/02/2026
Var
a, b, c, delta, x1, x2: real


Inicio

      escreval("Coeficiente a: ")
          leia(a)

      escreval("Coeficiente b: ")
          leia(b)

      escreval("Coeficiente c: ")
          leia(c)
          
          1x^2+0x-9=



Fimalgoritmo