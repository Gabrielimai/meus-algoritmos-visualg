Algoritmo "teste_enquanto"


// Data atual  : 26/02/2026
Var

   x, soma : inteiro


Inicio

   escreva("Digite o primeiro número: ")
   leia(x)
   
   soma <- 0

   enquanto x <> 0 faca
   soma <- soma + x
      escreva("Escreva outro número: ")
      leia(x)
   fimenquanto
   escreva("SOMA: ",soma )

Fimalgoritmo